# LIBRARIES #
xontrib load coreutils
# SOURCE SCRIPTS #

# STARTUP MESSAGE #
print("Welcome to xonsh shell!")

# PATH #
$PATH.append('/bin')
$PATH.append('/usr/bin')
$PATH.append('/root/.local/bin')

# ENV VARIABLES #
$PAGER = "less"
$EDITOR = "nvim"

$GITHUB = "git@github.com:tgnlex"

$DOTFILES_DIR = "/dotfiles"
$CONFIGS_DIR = "/configs"
$REPOS_DIR = "/repos"

$XONSHRC_SRC = "/dotfiles/.xonshrc"
$BASHRC_SRC = "/dotfiles/.bashrc"
$TCSHRC_SRC = "/dotfiles/.tcshrc"
$ZSHRC_SRC = "/dotfiles/.zshrc"

$XONSH_ALIASES_SRC = "/configs/xsh/aliases.xsh"
$XONSH_SCRIPTS_SRC = "/configs/xsh/scripts.xsh"

# SOURCE FILES #
source "~/scripts.xsh"
source "~/aliases.xsh"
