# LIBRARIES #
xontrib load coreutils
# STARTUP MESSAGE #
print("Welcome to xonsh shell!")

# PATH #
$PATH.append('/bin')
$PATH.append('/usr/bin')
$PATH.append('/root/.local/bin')

# ENV #

$EDITOR = "nvim"
$GITHUB = "git@github.com:tgnlex"
$XONSHRC_SRC = "/dotfiles/.xonshrc"
$BASHRC_SRC = "/dotfiles/.bashrc"
$TCSHRC_SRC = "/dotfiles/.tcshrc"
$ZSHRC_SRC = "/dotfiles/.zshrc"
$SCRIPTS = "/repos/scripts"

# ALIASES #
aliases['la'] = 'ls -a'
aliases['rf'] = 'rm -rf'
aliases['pip'] = 'xpip'
aliases['venv'] = 'bash /.venv/bin/activate'
aliases['unlock'] = 'chmod 777 -R'
aliases['git-save'] = 'git add . && git commit -a -m "auto-commit"'
aliases['git-update'] = 'git-save && git push'

aliases['edit-xonsh'] = "$EDITOR $XONSHRC_SRC"
aliases['edit-bash'] = "$EDITOR $BASHRC_SRC"
aliases['edit-tcsh'] = "$EDITOR $TCSHRC_SRC"
aliases['edit-zsh'] = "$EDITOR $ZSHRC_SRC"

aliases['update-xonsh'] = "cp -r $XONSHRC_SRC /root/ && cp -r $XONSHRC_SRC /home/alex/ && source ~/.xonshrc"
aliases['update-bash'] = "cp -r $BASHRC_SRC /root/ && cp -r $BASHRC_SRC /home/alex/"
aliases['update-tcsh'] = "cp -r $TCSHRC_SRC /root/ && cp -r $TCSHRC_SRC /home/alex/"
aliases['update-zsh'] = "cp -r $ZSHRC_SRC /root/ && cp -r $ZSHRC_SRC /home/alex/"

