# LIBRARIES #
xontrib load coreutils
# SOURCE SCRIPTS #

# STARTUP MESSAGE #
print("Welcome to xonsh shell!")

# PATH #
$PATH.append('/bin')
$PATH.append('/usr/bin')
$PATH.append('/root/.local/bin')

# ENV VARIABLES #
$JAVA = '/usr/bin/java'
$PAGER = "less"
$EDITOR = "nvim"


$GITHUB = "git@github.com:tgnlex" 

$REPOS_DIR = "/repos"        # Actual repos directory
$CONFIGS_DIR = "/configs"    # Soft link to /repos/linux/arch
$DOTFILES_DIR = "/dotfiles"  # Soft link to /repos/linux/arch/dotfiles

$XONSHRC_SRC = "/dotfiles/.xonshrc"  # XONSHRC MAIN SOURCE FILE
$BASHRC_SRC = "/dotfiles/.bashrc"    # BASHRC MAIN SOURCE FILE
$TCSHRC_SRC = "/dotfiles/.tcshrc"    # TCSHRC MAIN SOURCE FILE 
$ZSHRC_SRC = "/dotfiles/.zshrc"      # ZSHRC MAIN SOURCE FILE 
$KSHRC_SRC = "/fotfiles/.kshrc"      # KSHRC MAIN SOURCE FILE

$XONSH_ALIASES_SRC = "/configs/xsh/aliases.xsh"
$XONSH_SCRIPTS_SRC = "/configs/xsh/scripts.xsh"

# SOURCE FILES #
source "~/scripts.xsh" # Functions to call from command line # 
source "~/aliases.xsh" # Similar to .bash_aliases #
